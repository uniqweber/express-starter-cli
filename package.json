{
  "name": "@uniqweber/express-starter",
  "version": "1.0.2",
  "description": "CLI to generate a DDD-based ExpressJS starter project",
  "bin": {
    "express-starter": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "keywords": [
    "@uniqweber",
    "express",
    "typescript",
    "ddd",
    "cli",
    "starter",
    "boilerplate"
  ],
  "author": "Rayan (uniqweber)",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@uniqweber/express-starter": "^1.0.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "execa": "^5.1.1",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uniqweber/express-starter-cli.git"
  },
  "bugs": {
    "url": "https://github.com/uniqweber/express-starter-cli/issues"
  },
  "homepage": "https://github.com/uniqweber/express-starter-cli#readme"
}